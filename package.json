{
	"name": "workspace",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --filter '@apps/*' dev",
		"build": "bun run --filter '@apps/*' build",
		"start": "bun run --filter '@apps/*' start",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun run --filter '@packages/*' test",
		"create": "bun scripts/create.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"catalog": {
		"hono": "^4",
		"drizzle-orm": "^0.45.2",
		"drizzle-kit": "^0.31.10"
	}
}
