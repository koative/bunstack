{
	"name": "arcstack",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --filter '@apps/*' dev",
		"build": "bun run --filter '@apps/*' build",
		"start": "bun run --filter '@apps/*' start",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun run --filter './packages/*' test"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"catalog": {
		"next": "^16.2.4",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/node": "^22",
		"tailwindcss": "^4",
		"tw-animate-css": "^1",
		"shadcn": "^4.4.0",
		"@tailwindcss/postcss": "^4",
		"next-themes": "^0.4.6",
		"hono": "^4",
		"drizzle-orm": "^0.45.2",
		"drizzle-kit": "^0.31.10"
	}
}
